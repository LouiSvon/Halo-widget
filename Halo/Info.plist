<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Identité -->
    <key>CFBundleName</key>
    <string>Halo</string>
    <key>CFBundleIdentifier</key>
    <string>com.louis.halo</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <!-- Pas d'icône dock, app menubar uniquement -->
    <key>LSUIElement</key>
    <true/>

    <!-- URL scheme pour le callback OAuth Spotify -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>halo</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.louis.halo</string>
        </dict>
    </array>

    <!-- Bluetooth -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Halo affiche vos appareils Bluetooth connectés et vous permet de les déconnecter.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Halo affiche vos appareils Bluetooth connectés et vous permet de les déconnecter.</string>

    <!-- Réseau (pour l'API Spotify) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>
</dict>
</plist>
